html
  background: #f4f6f8

body
  background: #f4f6f8
  color: #263238
  font-size: 16px
  line-height: 1.75

#wrap
  background: #f4f6f8

a
  color: #0b7fab

.outer
  max-width: 1180px
  padding-left: 28px
  padding-right: 28px

#header
  height: 220px
  border-bottom: 1px solid #dce2e8
  &:before
    height: 96px
    background: linear-gradient(rgba(0, 0, 0, 0.56), rgba(0, 0, 0, 0.08), transparent)
  &:after
    height: 80px
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.18))

#header-title
  top: 52%
  height: auto
  margin-top: -44px

#logo
  display: block
  font-size: 38px
  line-height: 1.2
  letter-spacing: 0
  font-weight: 400

#subtitle
  font-size: 16px
  line-height: 1.5
  letter-spacing: 0
  opacity: 0.92

#subtitle-wrap
  margin-top: 10px

#main-nav
  margin-left: -10px

.main-nav-link,
.nav-icon
  padding: 18px 10px
  letter-spacing: 0
  opacity: 0.82
  font-weight: 500

#sub-nav
  margin-right: -10px

#content.outer
  padding-top: 34px
  padding-bottom: 48px
  @media mq-normal
    display: grid
    grid-template-columns: minmax(0, 1fr) 300px
    column-gap: 40px
    align-items: start

if sidebar and sidebar isnt bottom
  #main
    @media mq-normal
      display: block
      width: 100%
      max-width: 100%
      float: none
      margin: 0
      min-width: 0
      grid-column: 1

  #sidebar
    @media mq-normal
      display: block
      width: 100%
      max-width: 300px
      float: none
      margin: 0
      min-width: 0
      grid-column: 2

.article,
.archives-wrap,
.widget-wrap
  margin-top: 0
  margin-bottom: 28px

.article-inner,
.archive-article-inner,
.widget,
#page-nav
  background: #fff
  border: 1px solid #dfe5ec
  border-radius: 8px
  box-shadow: 0 8px 22px rgba(36, 49, 66, 0.06)

.article-header
  padding: 28px 30px 0

.article-title
  color: #2d3742
  font-size: 28px
  line-height: 1.32
  letter-spacing: 0

.article-entry
  color: #33414d
  padding: 4px 30px 8px
  font-size: 16px
  line-height: 1.78
  p,
  table
    line-height: 1.78
    margin: 1em 0
  h1,
  h2,
  h3,
  h4,
  h5,
  h6
    color: #24313d
    line-height: 1.36
    letter-spacing: 0
    margin: 1.45em 0 0.6em
  h2
    font-size: 23px
    padding-bottom: 8px
    border-bottom: 1px solid #e6ebf0
  h3
    font-size: 19px
  ul,
  ol,
  dl
    margin-top: 0.75em
    margin-bottom: 0.75em
  li
    margin: 0.18em 0
  blockquote
    margin: 1.1em 0
    padding: 12px 16px
    color: #455866
    background: #f7fafb
    border-left: 4px solid #8aa7b4
    font-family: font-sans
    text-align: left
  code
    padding: 0.12em 0.35em
    border-radius: 4px
    background: #eef3f6
    color: #2a4858
  table
    display: block
    overflow-x: auto
    border: 1px solid #e2e8ef
    border-radius: 8px
  th,
  td
    padding: 10px 12px
  th
    background: #f5f8fa

.article-footer
  margin: 0 30px 26px
  color: #71808c

.article-date,
.article-category-link,
.archive-year,
.widget-title
  letter-spacing: 0
  text-transform: none
  text-shadow: none

.article-date,
.article-category-link
  color: #7b8792
  font-size: 14px

.article-category
  color: #b5c0ca

.article-more-link a
  border-radius: 8px
  background: #edf5f8
  color: #0b7fab
  text-shadow: none
  font-weight: 600
  &:hover
    background: #0b7fab
    color: #fff

.stack-map
  margin-top: 8px

.stack-map-lead
  margin: 0 0 24px !important
  color: #52626f
  font-size: 15px
  line-height: 1.8

.stack-domain
  display: grid
  grid-template-columns: 170px minmax(0, 1fr)
  column-gap: 26px
  padding: 24px 0
  border-top: 1px solid #e4eaf0
  &:first-of-type
    border-top: 0
    padding-top: 4px

.stack-domain-head h2
  margin: 0 0 8px !important
  padding: 0 !important
  border-bottom: 0 !important
  font-size: 21px
  line-height: 1.35

.stack-domain-head p
  margin: 0 !important
  color: #71808c
  font-size: 14px
  line-height: 1.65

.stack-topic-list
  display: grid
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr))
  gap: 14px 22px
  margin: 0 !important
  list-style: none !important

.stack-topic
  margin: 0 !important
  padding: 0 0 12px
  border-bottom: 1px solid #edf2f6
  a,
  strong
    display: inline-block
    margin-bottom: 4px
    color: #0b7fab
    font-weight: 700
    text-decoration: none
  a:hover
    color: #075c7f
    text-decoration: underline
  span
    display: block
    color: #647482
    font-size: 13px
    line-height: 1.6

.stack-topic.is-planned
  a,
  strong
    color: #7d8994
  span
    color: #8a98a4

.archives-wrap
  padding: 0

.archive-year-wrap
  margin-bottom: 14px

.archive-year
  display: inline-block
  margin-left: 2px
  color: #7b8792
  font-size: 22px
  line-height: 1.2
  font-weight: 700
  text-decoration: none

.archives
  column-count: auto
  column-gap: 0
  display: flex
  flex-direction: column
  gap: 10px

.archive-article
  break-inside: auto

.archive-article-inner
  margin-bottom: 0
  padding: 15px 18px
  transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease
  &:hover
    border-color: #bcd4df
    box-shadow: 0 10px 26px rgba(36, 49, 66, 0.09)
    transform: translateY(-1px)

.archive-article-date
  color: #7f8b96
  font-size: 14px
  line-height: 1.3
  margin-bottom: 5px

.archive-article-title
  color: #2d3742
  font-size: 17px
  line-height: 1.55
  letter-spacing: 0
  &:hover
    color: #0b7fab

.widget-title
  margin: 0 0 12px
  color: #697986
  font-size: 16px
  line-height: 1.3
  font-weight: 700

.widget
  color: #4f5f6c
  text-shadow: none
  padding: 16px 18px
  box-shadow: 0 8px 22px rgba(36, 49, 66, 0.05)
  ul,
  ol
    margin: 0
    line-height: 1.7
    list-style-position: inside
  li
    margin: 2px 0
  a
    color: #0b7fab
    text-decoration: none
    &:hover
      color: #075c7f
      text-decoration: underline

.category-list,
.tag-list,
.archive-list
  list-style: none

.category-list-child
  margin-left: 12px !important
  padding-left: 14px
  border-left: 1px solid #d8e4ea
  list-style: none !important

.category-list-item
  margin: 4px 0 !important

.category-list-child .category-list-item
  margin: 3px 0 !important

.tag-list
  display: flex
  flex-wrap: wrap
  gap: 8px
  line-height: 1.2 !important

.tag-list-item
  margin: 0 !important

.tag-list-link
  display: inline-block
  padding: 4px 8px
  border-radius: 999px
  background: #eef6f8
  font-size: 13px

.recent-posts,
.archive-list
  li
    border-top: 1px solid #edf1f4
    padding-top: 8px
    margin-top: 8px
    &:first-child
      border-top: 0
      padding-top: 0
      margin-top: 0

#page-nav
  margin: 30px 0
  overflow: hidden

#footer
  background: #23292f

@media screen and (max-width: 767px)
  .outer
    padding-left: 18px
    padding-right: 18px

  #header
    height: 168px

  #header-title
    top: 54%
    margin-top: -34px

  #logo
    font-size: 30px

  #subtitle
    font-size: 14px

  #content.outer
    padding-top: 24px
    display: block

  #main
    width: 100%
    float: none
    margin-right: 0

  #sidebar
    width: 100%
    float: none

  .article-header
    padding: 22px 20px 0

  .article-title
    font-size: 23px

  .article-entry
    padding-left: 20px
    padding-right: 20px

  .stack-domain
    display: block

  .stack-domain-head
    margin-bottom: 14px

  .stack-topic-list
    grid-template-columns: 1fr
    gap: 12px

  .article-footer
    margin-left: 20px
    margin-right: 20px

  .archive-article-inner
    padding: 14px 15px
